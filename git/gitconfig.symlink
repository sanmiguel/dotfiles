[url "https://github.com/"]
	insteadOf = git://github.com/

## This literally only matches https://, even with the rewrite rule above
[includeIf "hasconfig:remote.*.url:https://github.com/**"]
        path = /Users/sanmiguel/.gitconfig.github

[includeIf "hasconfig:remote.*.url:git://github.com/**"]
        path = /Users/sanmiguel/.gitconfig.github

## :** doesn't work like /**
[includeIf "hasconfig:remote.*.url:git@github.com:*/*"]
        path = /Users/sanmiguel/.gitconfig.github

## This literally only matches https://, even with the rewrite rule above
[includeIf "hasconfig:remote.*.url:https://192.168.3.78/**"]
        path = /Users/sanmiguel/.gitconfig.forgejo

[includeIf "hasconfig:remote.*.url:git://192.168.3.78/**"]
        path = /Users/sanmiguel/.gitconfig.forgejo

## :** doesn't work like /**
[includeIf "hasconfig:remote.*.url:forgejo@192.168.3.78:*/*"]
        path = /Users/sanmiguel/.gitconfig.forgejo

[color]
	diff = auto
	status = auto
	ui = auto
[core]
	excludesfile = /Users/sanmiguel/dotfiles/git/gitignore
[help]
	autocorrect = 1
[dude]
	interval = 30
	notify-command = terminal-notifier -message \"$DESCRIPTION\" -title \"$TITLE\"
[merge]
	tool = diffconflicts
[branch]
	autosetuprebase = always
[push]
	default = current
[mergetool "diffconflicts"]
	cmd = nvim -c DiffConflicts $MERGED $BASE $LOCAL $REMOTE
	trustExitCode = true
[mergetool]
	keepBackup = false
[pull]
	rebase = true
[rebase]
	autoStash = true
[commit]
	gpgsign = true
[gpg]
	format = ssh
[gpg "ssh"]
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
[init]
	defaultBranch = main
[alias]
    oldest-ancestor = !zsh -c 'diff -u <(git rev-list --first-parent "${1:-master}") <(git rev-list --first-parent "${2:-HEAD}") | sed -ne \"s/^ //p\" | head -1' -
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
